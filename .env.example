# Copy to .env (or set as real environment variables) and adjust as needed.
# On Windows PowerShell, set each with:  $env:APP_JWT_SECRET="..."

# JWT signing secret. MUST be at least 32 characters.
APP_JWT_SECRET=change-this-secret-in-production-min-32-bytes-long!!

# Where uploaded attachments are stored on disk.
APP_UPLOAD_DIR=uploads

# --- Optional generative-AI feature (disabled by default) ---
# Set APP_AI_ENABLED=true and provide a key to enable POST /api/ai/generate-description
APP_AI_ENABLED=false
ANTHROPIC_API_KEY=
APP_AI_MODEL=claude-sonnet-4-6

# --- PostgreSQL connection (default datasource) ---
# Start a local instance with `docker compose up -d`, or point at any Postgres server.
DB_URL=jdbc:postgresql://localhost:5432/taskmaster
DB_USERNAME=taskmaster
DB_PASSWORD=taskmaster

# --- CORS: comma-separated origins allowed to call this API ---
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
